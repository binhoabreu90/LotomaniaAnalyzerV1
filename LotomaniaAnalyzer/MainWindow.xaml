<Window x:Class="LotomaniaAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lotomania Analyzer v1.0"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0"
                   Text="LOTOMANIA ANALYZER v1.0"
                   FontSize="32"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>

        <!-- Botões -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center">

            <Button Content="Importar Concursos"
                    Width="180"
                    Height="40"
                    Margin="10"/>

            <Button Content="Iniciar Busca"
                    Width="150"
                    Height="40"
                    Margin="10"/>

            <Button Content="Pausar"
                    Width="100"
                    Height="40"
                    Margin="10"/>

            <Button Content="Continuar"
                    Width="120"
                    Height="40"
                    Margin="10"/>

            <Button Content="Parar"
                    Width="100"
                    Height="40"
                    Margin="10"/>

        </StackPanel>


        <!-- Estatísticas -->
        <GroupBox Grid.Row="2"
                  Header="Estatísticas"
                  FontSize="18">

            <StackPanel Margin="10">

                <TextBlock Text="Concursos carregados: 0"/>
                <TextBlock Text="Cartelas geradas: 0"/>
                <TextBlock Text="Cartelas analisadas: 0"/>
                <TextBlock Text="Descartadas F001: 0"/>

            </StackPanel>

        </GroupBox>


        <!-- Ranking -->
        <GroupBox Grid.Row="3"
                  Header="TOP 10 Cartelas"
                  FontSize="18"
                  Margin="0,20,0,0">

            <TextBlock Text="Aguardando análise..."
                       FontSize="20"
                       Margin="20"/>

        </GroupBox>


    </Grid>

</Window>
